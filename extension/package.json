{
  "name": "semanticguard-gatekeeper",
  "displayName": "SemanticGuard Gatekeeper 🛡️",
  "description": "Architectural airbag — blocks file saves that violate your project's .semanticguard/ pillar rules.",
  "version": "2.5.1",
  "publisher": "trepansec",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/dsadsadsadsadas/SemanticGuard"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icons/icon128.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "semanticguard.status",
        "title": "SemanticGuard: Show Server Status"
      },
      {
        "command": "semanticguard.toggleEnabled",
        "title": "SemanticGuard: Toggle Airbag On/Off"
      },
      {
        "command": "semanticguard.askGatekeeper",
        "title": "🛡️ Ask SemanticGuard"
      },
      {
        "command": "semanticguard.openLedger",
        "title": "🛡️ Open SemanticGuard Ledger"
      },
      {
        "command": "semanticguard.reviewWithLedger",
        "title": "🔍 SemanticGuard: Review Changes vs. Walkthrough"
      },
      {
        "command": "semanticguard.initializeProject",
        "title": "⚡ SemanticGuard: Initialize Project"
      },
      {
        "command": "semanticguard.toggleProcessor",
        "title": "🛡️ SemanticGuard: Toggle CPU/GPU Mode"
      },
      {
        "command": "semanticguard.selectModel",
        "title": "SemanticGuard: Select Audit Model",
        "category": "SemanticGuard"
      },
      {
        "command": "semanticguard.auditEntireFolder",
        "title": "SemanticGuard: Audit Entire Folder",
        "category": "SemanticGuard"
      },
      {
        "command": "semanticguard.configureBYOK",
        "title": "🚀 SemanticGuard: Configure Power Mode (BYOK)",
        "category": "SemanticGuard"
      },
      {
        "command": "semanticguard.togglePowerMode",
        "title": "⚡ SemanticGuard: Toggle Power Mode",
        "category": "SemanticGuard"
      },
      {
        "command": "semanticguard.toggleV2Prompts",
        "title": "🧪 SemanticGuard: Toggle V2 Prompts (Experimental)",
        "category": "SemanticGuard"
      },
      {
        "command": "semanticguard.debugReasoning",
        "title": "🔍 SemanticGuard: Toggle Debug Reasoning",
        "category": "SemanticGuard"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "semanticguard.askGatekeeper",
          "group": "navigation"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "semanticguard.reviewWithLedger",
          "group": "inline"
        }
      ],
      "scm/title": [
        {
          "command": "semanticguard.reviewWithLedger",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "semanticguard-sidebar",
          "title": "SemanticGuard Architect",
          "icon": "resources/semanticguard-icon-v2.svg"
        }
      ]
    },
    "views": {
      "semanticguard-sidebar": [
        {
          "id": "semanticguard.explorer",
          "name": "Logic Gate Status",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "SemanticGuard Gatekeeper",
      "properties": {
        "semanticguard.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8001",
          "description": "URL of the SemanticGuard inference server"
        },
        "semanticguard.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the save airbag"
        },
        "semanticguard.timeoutMs": {
          "type": "number",
          "default": 300000,
          "description": "Max ms to wait for server response before failing open"
        },
        "semanticguard.excludePatterns": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/*.md",
            "**/*.json",
            "**/*.lock"
          ],
          "description": "Glob patterns to skip evaluation (always allowed to save)"
        },
        "semanticguard.enforcementMode": {
          "type": "string",
          "default": "Soft",
          "enum": [
            "Soft",
            "Strict"
          ],
          "description": "If Strict, network timeouts or server unreachability will rigorously block the save instead of allowing an open-fail."
        },
        "semanticguard.processor_mode": {
          "type": "string",
          "default": "GPU",
          "enum": [
            "GPU",
            "CPU"
          ],
          "description": "Processor to use for inference (GPU for speed, CPU for battery/resource saving)"
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "fast-check": "^3.15.0"
  }
}