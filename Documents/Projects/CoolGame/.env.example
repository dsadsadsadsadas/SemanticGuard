# ShadowGrid Environment Configuration
# Copy this file to .env and fill in your values

# Groq API Key for Tier 2 Visual Analysis (Llama 3.1)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Server Configuration (optional)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Anti-Cheat Settings (optional)
DETECTION_ENABLED=true
TIER2_ENABLED=true

# Debug Mode (optional)
DEBUG=false
